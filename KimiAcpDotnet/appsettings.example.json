{
  "ActiveProfile": "kimi-local",
  "Profiles": {
    "kimi-local": {
      "ExecutablePath": "kimi",
      "Arguments": ["acp"],
      "WorkingDirectory": "../..",
      "DefaultPrompt": "Summarize the repository layout in two bullet points.",
      "TimeoutSeconds": 30,
      "EnvironmentVariables": {
        "KIMI_API_KEY": "",
        "KIMI_BASE_URL": ""
      },
      "Client": {
        "Name": "KimiAcpDotnet",
        "Version": "0.1.0",
        "ProtocolVersion": 1
      },
      "Authentication": {
        "PreferredMethodId": "token",
        "MethodInfo": {
          "token": ""
        }
      },
      "SessionDefaults": {
        "Model": "kimi-default",
        "ModeId": "analysis",
        "Metadata": {
          "approvalPolicy": "never",
          "workspaceScope": "monorepo"
        }
      },
      "Artifacts": {
        "RunStorePath": "./.kimi-acp-runs"
      }
    }
  }
}
