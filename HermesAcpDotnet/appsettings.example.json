{
  "ActiveProfile": "hermes-local",
  "Profiles": {
    "hermes-local": {
      "ExecutablePath": "hermes",
      "Arguments": ["acp"],
      "WorkingDirectory": "../..",
      "DefaultPrompt": "Summarize the repository layout in two bullet points.",
      "TimeoutSeconds": 30,
      "EnvironmentVariables": {
        "HERMES_API_KEY": "",
        "HERMES_BASE_URL": ""
      },
      "Client": {
        "Name": "HermesAcpDotnet",
        "Version": "0.1.0",
        "ProtocolVersion": 1
      },
      "Authentication": {
        "PreferredMethodId": "token",
        "MethodInfo": {
          "token": ""
        }
      },
      "SessionDefaults": {
        "Model": "hermes-default",
        "ModeId": "analysis",
        "Metadata": {
          "approvalPolicy": "never",
          "workspaceScope": "monorepo"
        }
      },
      "Artifacts": {
        "RunStorePath": "./.hermes-acp-runs"
      }
    }
  }
}
