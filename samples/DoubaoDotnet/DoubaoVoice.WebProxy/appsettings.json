{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/doubao-proxy-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  },
  "DoubaoProxy": {
    "AppId": "your-app-id",
    "AccessToken": "your-access-token",
    "ServiceUrl": "wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async",
    "ResourceId": "volc.bigasr.sauc.duration",
    "SampleRate": 16000,
    "BitsPerSample": 16,
    "Channels": 1,
    "AudioFormat": "wav",
    "AudioCodec": "raw",
    "ModelName": "bigmodel",
    "EnableITN": true,
    "EnablePunctuation": true,
    "EnableDDC": true,
    "ShowUtterances": true,
    "EnableNonstream": false,
    "Uid": "demo_uid",
    "Did": "",
    "Platform": "dotnet",
    "SdkVersion": "1.0.0",
    "AppVersion": "1.0.0",
    "BufferSize": 10,
    "BufferTimeoutMs": 5000,
    "ChunkSizeBytes": 3200,
    "ConfidenceThreshold": 0.5,
    "ListenUrl": "http://localhost:5000"
  }
}
